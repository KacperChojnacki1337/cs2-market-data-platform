# ── Airflow core ──────────────────────────────────────────────────────────────
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:${POSTGRES_PASSWORD}@postgres/airflow
AIRFLOW__CORE__FERNET_KEY=<generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())">
AIRFLOW__WEBSERVER__SECRET_KEY=<random string, e.g. openssl rand -hex 32>
AIRFLOW__CORE__DAGS_ARE_PAUSED_AT_CREATION=false
AIRFLOW__CORE__LOAD_EXAMPLES=false

# ── Postgres ──────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=changeme

# ── Airflow admin user ────────────────────────────────────────────────────────
AIRFLOW_ADMIN_EMAIL=your@email.com
AIRFLOW_ADMIN_PASSWORD=changeme

# ── AWS (Lambda invocations) ──────────────────────────────────────────────────
AWS_DEFAULT_REGION=eu-central-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── GCP (dbt → BigQuery) ──────────────────────────────────────────────────────
# Host path to the service account JSON — mounted read-only into the container.
# Copy the key from SSM: aws ssm get-parameter --name /steam-tracker/gcp-key --with-decryption --query Parameter.Value --output text > gcp-key.json
GCP_KEY_HOST_PATH=/path/on/host/to/gcp-key.json
GOOGLE_APPLICATION_CREDENTIALS=/opt/airflow/gcp-key.json

# ── Pipeline config ───────────────────────────────────────────────────────────
LAMBDA_FUNCTION_NAME=steam_price_producer
LAMBDA_REGION=eu-central-1
DBT_PROJECT_DIR=/opt/airflow/dbt/steam_tracker
DBT_PROFILES_DIR=/opt/airflow/dbt/steam_tracker
GCP_PROJECT_ID=steam-tracker-portfolio